{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.contextstreamio/mcp-server",
  "title": "ContextStream MCP Server",
  "description": "ContextStream MCP server for code context, memory, search, and AI tools.",
  "version": "0.4.70",
  "repository": {
    "url": "https://github.com/contextstream/mcp-server",
    "source": "github"
  },
  "websiteUrl": "https://contextstream.io/docs/mcp",
  "tags": [
    "code-context",
    "memory",
    "search",
    "knowledge-graph",
    "ai-tools"
  ],
  "icons": [
    {
      "src": "https://contextstream.io/favicon.svg",
      "mimeType": "image/svg+xml",
      "sizes": [
        "any"
      ]
    },
    {
      "src": "https://contextstream.io/logo.png",
      "mimeType": "image/png",
      "sizes": [
        "512x512"
      ]
    }
  ],
  "remotes": [
    {
      "type": "streamable-http",
      "url": "https://mcp.contextstream.io/mcp",
      "headers": {
        "X-ContextStream-Toolset": "complete",
        "X-ContextStream-Output-Format": "compact",
        "X-ContextStream-Search-Limit": "15",
        "X-ContextStream-Search-Max-Chars": "2400",
        "X-ContextStream-Transcripts-Enabled": "true",
        "X-ContextStream-Consolidated": "true"
      }
    }
  ]
}
